{
  "name": "@rive-viewmodel/cli",
  "version": "0.1.0",
  "description": "CLI to generate ViewModel code from Rive (.riv) files",
  "type": "module",
  "license": "BSD-3-Clause",
  "bin": {
    "rive-gen": "dist/bin/rive-gen.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "dev": "node --import tsx bin/rive-gen.ts",
    "start": "node dist/bin/rive-gen.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@rive-app/canvas-advanced": "^2.36.0",
    "commander": "^12.0.0",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
