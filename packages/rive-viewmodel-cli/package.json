{
  "name": "@rive-viewmodel/cli",
  "version": "0.1.0",
  "description": "CLI to generate ViewModel code from Rive (.riv) files",
  "type": "module",
  "bin": {
    "rive-gen": "./dist/bin/rive-gen.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --loader tsx/esm bin/rive-gen.ts",
    "start": "node dist/bin/rive-gen.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rive-app/canvas-advanced": "^2.36.0",
    "commander": "^12.0.0",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
